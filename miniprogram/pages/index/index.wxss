page { background: #0f0f1a; }
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}
.title-wrap { text-align: center; margin-bottom: 60rpx; }
.main-title { font-size: 100rpx; display: block; }
.game-title { font-size: 52rpx; font-weight: bold; color: #fff; display: block; margin-bottom: 12rpx; }
.subtitle { font-size: 26rpx; color: #888; display: block; }
.panel {
  background: #1a1a2e;
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 40rpx;
  padding: 48rpx 40rpx;
  width: 100%;
}
.panel-title { font-size: 26rpx; color: #888; margin-bottom: 16rpx; display: block; }
.input {
  width: 100%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.15);
  color: #fff;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
}
.btn-primary { width: 100%; margin-bottom: 32rpx; }
.btn-secondary { width: 100%; }
.divider { text-align: center; color: #555; font-size: 24rpx; margin: 32rpx 0; }
.loading-tip { color: #888; font-size: 26rpx; margin-top: 32rpx; }
