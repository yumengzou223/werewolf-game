page { background: #0f0f1a; }
.game-wrap { min-height: 100vh; background: #0f0f1a; color: #e0e0e0; }

/* Toast */
.toast {
  position: fixed; top: 40rpx; left: 50%; transform: translateX(-50%);
  background: rgba(0,0,0,0.85); color: #fff;
  padding: 20rpx 48rpx; border-radius: 100rpx;
  font-size: 26rpx; z-index: 9999;
  opacity: 0; transition: opacity 0.3s; pointer-events: none;
}
.toast.show { opacity: 1; }

/* 等待房间 */
.page-waiting { display: flex; flex-direction: column; min-height: 100vh; }
.room-header {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx 32rpx;
  background: rgba(255,255,255,0.05);
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}
.conn-dot { font-size: 24rpx; }
.room-id-box {
  background: rgba(102,126,234,0.2);
  border: 1rpx solid rgba(102,126,234,0.4);
  padding: 8rpx 24rpx; border-radius: 40rpx;
  font-size: 26rpx; font-weight: bold; letter-spacing: 4rpx;
}
.btn-sm {
  background: rgba(255,255,255,0.1); color: #fff;
  border: 1rpx solid rgba(255,255,255,0.2);
  padding: 10rpx 24rpx; border-radius: 40rpx; font-size: 24rpx;
}
.players-grid {
  display: flex; flex-wrap: wrap; gap: 20rpx;
  padding: 32rpx; flex: 1;
}
.player-slot {
  width: calc(33.33% - 14rpx);
  background: #1a1a2e;
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 24rpx; padding: 32rpx 16rpx;
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
}
.player-avatar {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; font-weight: bold; color: #fff;
  background: #95a5a6;
}
.player-name { font-size: 24rpx; color: #fff; text-align: center; }
.player-badge { font-size: 24rpx; }
.waiting-actions {
  display: flex; gap: 20rpx; justify-content: center;
  padding: 24rpx 32rpx 48rpx;
}
.waiting-actions .btn-secondary { flex: 1; }
.waiting-actions .btn-primary { flex: 1; }

/* 夜间页 */
.page-night {
  min-height: 100vh;
  background: radial-gradient(ellipse at 50% 0%, #1a1a3e 0%, #0d0d1a 60%, #000 100%);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 40rpx;
}
.night-overlay { width: 100%; display: flex; flex-direction: column; align-items: center; }
.phase-label { font-size: 48rpx; margin-bottom: 24rpx; color: rgba(255,255,255,0.8); }
.night-instr { font-size: 30rpx; color: rgba(255,255,255,0.6); margin-bottom: 48rpx; text-align: center; }
.closed-eyes { display: flex; flex-direction: column; align-items: center; gap: 24rpx; margin-top: 60rpx; }
.eyes-emoji { font-size: 120rpx; }

/* 目标选择 */
.target-section { width: 100%; }
.prompt-text { font-size: 28rpx; text-align: center; margin-bottom: 24rpx; display: block; }
.players-row { display: flex; flex-wrap: wrap; gap: 16rpx; justify-content: center; margin-bottom: 32rpx; }
.player-chip {
  background: rgba(255,255,255,0.1);
  border: 2rpx solid rgba(255,255,255,0.15);
  padding: 20rpx 36rpx; border-radius: 100rpx;
  font-size: 28rpx; color: #fff;
}
.player-chip.selected { background: rgba(102,126,234,0.3); border-color: #667eea; }
.player-chip.wolf-teammate { background: rgba(231,76,60,0.15); border-color: rgba(231,76,60,0.5); color: #ff8888; }
.player-chip.teammate-selected { background: rgba(231,76,60,0.25); border-color: #e74c3c; }

/* 女巫 */
.witch-panel { width: 100%; }
.witch-section { margin-bottom: 32rpx; }
.witch-label { font-size: 26rpx; color: #aaa; display: block; margin-bottom: 16rpx; text-align: center; }
.btn-witch-heal, .btn-witch-skip {
  display: inline-block; padding: 16rpx 32rpx; border-radius: 100rpx;
  font-size: 26rpx; margin: 8rpx; border: none;
}
.btn-witch-heal { background: #27ae60; color: #fff; }
.btn-witch-skip { background: rgba(255,255,255,0.1); color: #aaa; }

.waiting-msg { text-align: center; color: #888; font-size: 28rpx; margin: 40rpx 0; }
.show-night-waiting { text-align: center; }

/* 角色弹窗 */
.role-badge-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.8);
  display: flex; align-items: center; justify-content: center; z-index: 500;
}
.role-badge-card {
  background: #1a1a2e; border: 2rpx solid #f39c12; border-radius: 32rpx;
  padding: 60rpx 80rpx; text-align: center;
}
.rbl { font-size: 24rpx; color: #888; display: block; margin-bottom: 16rpx; }
.rbn { font-size: 64rpx; font-weight: bold; display: block; margin-bottom: 16rpx; }
.rbh { font-size: 24rpx; color: #aaa; display: block; max-width: 400rpx; }

/* 夜间结果 */
.night-result-card {
  background: #1a1a2e; border-radius: 40rpx; padding: 60rpx 48rpx;
  text-align: center; width: 100%;
}
.result-title { font-size: 56rpx; display: block; margin-bottom: 40rpx; }
.dead-label { font-size: 28rpx; color: #888; display: block; margin-bottom: 20rpx; }
.dead-chip {
  background: rgba(231,76,60,0.15); border: 1rpx solid rgba(231,76,60,0.4);
  padding: 16rpx 32rpx; border-radius: 100rpx;
  display: inline-block; margin: 8rpx; font-size: 28rpx;
}
.no-dead { font-size: 32rpx; color: #4caf50; display: block; margin: 32rpx 0; }
.healed-tip { font-size: 26rpx; color: #52c41a; display: block; margin-top: 16rpx; }

/* 白天页 */
.page-day { display: flex; flex-direction: column; min-height: 100vh; }
.day-header {
  display: flex; align-items: center; gap: 20rpx;
  padding: 20rpx 32rpx;
  background: rgba(255,255,255,0.05);
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  position: sticky; top: 0; z-index: 10;
}
.day-badge {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  padding: 8rpx 24rpx; border-radius: 40rpx; font-size: 24rpx; font-weight: bold; color: #fff;
}
.phase-badge {
  background: rgba(102,126,234,0.2); border: 1rpx solid rgba(102,126,234,0.4);
  padding: 8rpx 24rpx; border-radius: 40rpx; font-size: 24rpx; color: #fff;
}
.dead-reveal { padding: 24rpx 32rpx; text-align: center; }
.vote-result-text { font-size: 28rpx; color: #fff; display: block; margin-bottom: 16rpx; }
.pk-hint { color: #e74c3c; font-size: 26rpx; display: block; margin-top: 16rpx; }

/* 发言区 */
.speaking-area {
  padding: 24rpx 32rpx;
  background: rgba(255,255,255,0.03);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.speaking-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.speaker-name { font-size: 36rpx; font-weight: bold; color: #fff; }
.timer-wrap { width: 200rpx; }
.timer-bar { height: 12rpx; border-radius: 6rpx; transition: width 1s linear; }
.timer-num { font-size: 22rpx; text-align: right; margin-top: 6rpx; }
.speech-progress { font-size: 22rpx; display: block; margin-bottom: 16rpx; }
.speech-input-wrap { display: flex; gap: 16rpx; align-items: flex-end; }
.speech-input {
  flex: 1; background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.12);
  color: #fff; padding: 20rpx 24rpx; border-radius: 20rpx;
  font-size: 28rpx; height: 120rpx;
}

/* 投票区 */
.vote-area {
  padding: 24rpx 32rpx;
  background: rgba(255,255,255,0.03);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.vote-title { font-size: 26rpx; color: #888; text-align: center; display: block; margin-bottom: 24rpx; }
.vote-chip {
  background: rgba(255,255,255,0.08); border: 2rpx solid rgba(255,255,255,0.12);
  padding: 24rpx 32rpx; border-radius: 20rpx; text-align: center; min-width: 120rpx;
}
.vote-chip.selected { background: rgba(231,76,60,0.2); border-color: #e74c3c; }
.vote-chip.top-voted { border-color: #e74c3c; }
.vp-name { font-size: 26rpx; display: block; }
.vp-tally { font-size: 22rpx; color: #e74c3c; display: block; }
.pk-chip {
  background: rgba(231,76,60,0.15); border: 2rpx solid rgba(231,76,60,0.4);
  padding: 24rpx 48rpx; border-radius: 20rpx; font-size: 28rpx; font-weight: bold; color: #fff;
}
.pk-chip.selected { background: rgba(231,76,60,0.3); border-color: #e74c3c; }
.voted-confirm { text-align: center; color: #667eea; font-size: 28rpx; display: block; padding: 20rpx; }
.vote-timer-wrap { height: 10rpx; background: rgba(255,255,255,0.08); border-radius: 5rpx; margin-top: 24rpx; overflow: hidden; }

/* 消息区 */
.messages-area { flex: 1; padding: 20rpx 32rpx; max-height: 50vh; }
.msg-system { text-align: center; font-size: 22rpx; color: #666; padding: 10rpx; }
.msg-bubble-wrap { display: flex; flex-direction: column; margin-bottom: 20rpx; }
.msg-me { align-items: flex-end; }
.msg-other { align-items: flex-start; }
.msg-name { font-size: 20rpx; color: #888; margin-bottom: 8rpx; }
.msg-bubble { max-width: 75%; padding: 18rpx 24rpx; border-radius: 24rpx; font-size: 26rpx; line-height: 1.5; }
.bubble-me { background: #667eea; color: #fff; border-bottom-right-radius: 6rpx; }
.bubble-other { background: rgba(255,255,255,0.1); color: #fff; border-bottom-left-radius: 6rpx; }

/* 玩家列表 */
.players-mini {
  display: flex; flex-wrap: wrap; gap: 12rpx;
  padding: 16rpx 32rpx;
  background: rgba(0,0,0,0.3);
  border-top: 1rpx solid rgba(255,255,255,0.06);
}
.pm-chip {
  display: flex; align-items: center; gap: 8rpx;
  background: rgba(255,255,255,0.06);
  padding: 8rpx 20rpx; border-radius: 40rpx; font-size: 22rpx;
}
.pm-chip.dead { opacity: 0.35; text-decoration: line-through; }
.pm-chip.me { border: 1rpx solid #667eea; }
.pm-dot { width: 14rpx; height: 14rpx; border-radius: 50%; }

/* 游戏结束 */
.page-end {
  min-height: 100vh; display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #0a0a15, #1a0a20); padding: 40rpx;
}
.end-card { text-align: center; width: 100%; }
.end-title { font-size: 56rpx; display: block; margin-bottom: 48rpx; }
.good-win { color: #4caf50; }
.wolf-win { color: #e74c3c; }
.all-roles { display: flex; flex-wrap: wrap; gap: 16rpx; justify-content: center; }
.role-reveal-card {
  background: #1a1a2e; border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 24rpx; padding: 24rpx 16rpx; text-align: center; width: calc(33.33% - 12rpx);
}
.role-reveal-card.dead { opacity: 0.4; }
.rrc-avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  margin: 0 auto 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: bold; color: #fff; background: #999;
}
.rrc-name { font-size: 24rpx; color: #fff; display: block; }
.rrc-role { font-size: 22rpx; display: block; margin-top: 6rpx; }
.rrc-status { font-size: 20rpx; color: #888; display: block; margin-top: 6rpx; }

/* 预言家弹窗 */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.8);
  display: flex; align-items: center; justify-content: center; z-index: 1000;
}
.seer-modal {
  background: #1a1a2e; border: 2rpx solid #f39c12; border-radius: 32rpx;
  padding: 60rpx 80rpx; text-align: center; max-width: 560rpx;
  display: flex; flex-direction: column; align-items: center; gap: 16rpx;
}
.seer-modal-title { font-size: 26rpx; color: #f39c12; font-weight: bold; }
.seer-modal-result { font-size: 40rpx; font-weight: bold; color: #fff; }

/* AI人设选择弹窗 */
.persona-modal {
  background: #1a1a2e; border: 2rpx solid rgba(102,126,234,0.5); border-radius: 32rpx;
  padding: 48rpx 40rpx; text-align: center; max-width: 600rpx; width: 90%;
}
.persona-modal-title { font-size: 32rpx; font-weight: bold; color: #fff; display: block; margin-bottom: 32rpx; }
.persona-list { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; text-align: left; }
.persona-item {
  background: rgba(255,255,255,0.06); border: 2rpx solid rgba(255,255,255,0.1);
  border-radius: 20rpx; padding: 24rpx 28rpx;
}
.persona-item.selected {
  background: rgba(102,126,234,0.2); border-color: #667eea;
}
.persona-name { font-size: 28rpx; font-weight: bold; color: #fff; display: block; margin-bottom: 6rpx; }
.persona-desc { font-size: 22rpx; color: #aaa; }
.persona-actions { display: flex; gap: 20rpx; }
.persona-actions .btn-secondary, .persona-actions .btn-primary { flex: 1; }
